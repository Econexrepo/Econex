# ══════════════════════════════════════════════════════════════════
#  Econex — .gitignore
#  Covers: Python (FastAPI) · Node.js (Vite/React) · IDEs · OS
# ══════════════════════════════════════════════════════════════════

# ── Secrets & environment files ────────────────────────────────────
.env
.env.*
!.env.example
*.env

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
*.spec
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.virtualenv/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Node / Vite / React ────────────────────────────────────────────
node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/
dist/
build/

# Vite cache
frontend/.vite/
.vite/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── IDEs & editors ─────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.project
.classpath

# ── OS files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Misc ───────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
.cache/
tmp/
temp/

# ── Econex project-specific ────────────────────────────────────────
# User-uploaded files (avatars, etc.) – keep folder structure via .gitkeep
backend/uploads/*
!backend/uploads/**/.gitkeep

# Generated ARDL model output CSVs (runtime artifacts)
ardloutputs/*.csv
